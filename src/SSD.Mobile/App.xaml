<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="SSD.Mobile.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <Color x:Key="SsdBackground">#F6F3EA</Color>
        <Color x:Key="SsdSurface">#FFFDF8</Color>
        <Color x:Key="SsdPrimary">#1F5E5B</Color>
        <Color x:Key="SsdSecondary">#C46B3C</Color>
        <Color x:Key="SsdText">#1C211F</Color>
        <Style TargetType="ContentPage">
            <Setter Property="BackgroundColor" Value="{StaticResource SsdBackground}" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{StaticResource SsdText}" />
        </Style>
    </Application.Resources>
</Application>
