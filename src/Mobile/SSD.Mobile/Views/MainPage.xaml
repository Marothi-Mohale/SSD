<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SSD.Mobile.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="SSD">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label FontAttributes="Bold" FontSize="28" Text="Special Sound &amp; Screen Discovery" />
            <Label Text="Pick a mood, choose whether you want music, movies, or both, and get tailored recommendations." />

            <Label FontAttributes="Bold" Text="Mood" />
            <Picker ItemsSource="{Binding Moods}" SelectedItem="{Binding SelectedMood}" />

            <HorizontalStackLayout Spacing="16">
                <HorizontalStackLayout Spacing="8">
                    <CheckBox IsChecked="{Binding IncludeMusic}" />
                    <Label VerticalTextAlignment="Center" Text="Music" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="8">
                    <CheckBox IsChecked="{Binding IncludeMovies}" />
                    <Label VerticalTextAlignment="Center" Text="Movies" />
                </HorizontalStackLayout>
            </HorizontalStackLayout>

            <Button Command="{Binding DiscoverCommand}" Text="Discover" />

            <CollectionView ItemsSource="{Binding Recommendations}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,12" Padding="16">
                            <VerticalStackLayout Spacing="8">
                                <Label FontAttributes="Bold" FontSize="20" Text="{Binding Title}" />
                                <Label FontAttributes="Italic" Text="{Binding Subtitle}" />
                                <Label Text="{Binding Description}" />
                                <Label FontAttributes="Bold" Text="Why it matches" />
                                <Label Text="{Binding WhyItMatches}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
